{
  "name": "@acvigue/ts-xbee-api",
  "description": "Node.js library for communicating with XBee/ZigBee devices in API mode",
  "version": "4.0.3",
  "homepage": "https://github.com/acvigue/ts-xbee-api",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "format:write": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-c8": "^0.33.0",
    "@vitest/ui": "^4.1.4",
    "eslint": "~10.2.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@11.0.0-dev.1005+sha512.91f84a392eea348ea4852a182912d2520273a4336f933b78cc44bc931eb999923c097e9433a9b355adc1f725725ea99082fc9f032a559df832632e764c92c798"
}
